<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>Error — SAML SP Demo</title>
  <link rel="stylesheet" href="/style.css" />
</head>
<body>
  <main class="card">
    <h1><%= title %></h1>
    <p><%= message %></p>
    <% if (detail) { %>
      <details open>
        <summary>Detail</summary>
        <pre class="token"><code><%= detail %></code></pre>
      </details>
    <% } %>
    <p><a class="button button--secondary" href="/">Back to start</a></p>
  </main>
</body>
</html>
