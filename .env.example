PORT=8080
SP_BASE_URL=http://localhost:8080
SP_ENTITY_ID=urn:fiscal-psft:saml-sp-demo
SESSION_SECRET=replace-with-a-32-byte-random-hex

IDP_METADATA_PATH=./fiscal-psft_cic-demo-platform_auth0app_com-metadata.xml
IDP_CERT_PATH=./fiscal-psft.pem

TOKEN_EXCHANGE_URL=https://fiscal-psft.cic-demo-platform.auth0app.com/oauth/token
TOKEN_EXCHANGE_CLIENT_ID=your-token-exchange-client-id
TOKEN_EXCHANGE_CLIENT_SECRET=your-token-exchange-client-secret
TOKEN_EXCHANGE_AUDIENCE=api://your-api-audience
TOKEN_EXCHANGE_SUBJECT_TOKEN_TYPE=https://fiscal-psft.com/token-type/oag-session

# Dedicated M2M client used only by the /profile page. The Auth0 client_grant
# on the Management API is restricted to read:users + update:users; the app
# code further restricts every call to /api/v2/users/{currently-authenticated-NameID}.
PROFILE_MGMT_TOKEN_URL=https://your-tenant.auth0.com/oauth/token
PROFILE_MGMT_AUDIENCE=https://your-tenant.auth0.com/api/v2/
PROFILE_MGMT_CLIENT_ID=your-profile-mgmt-client-id
PROFILE_MGMT_CLIENT_SECRET=your-profile-mgmt-client-secret
